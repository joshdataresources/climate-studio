# Copy to .env.local for local development overrides.

# Mapbox public token (pk.*) — optional override; app includes a default for GitHub Pages
# VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token

# Show the Location Analysis dashboard at /dashboard (hidden in production builds by default)
# VITE_ENABLE_LOCATION_DASHBOARD=true

# ── Earth Engine / climate API backend ──────────────────────────────────────
# Option A — use Render (no local Python needed; allow ~30s after server restart):
# VITE_NODE_BACKEND_URL=https://climate-studio-backend.onrender.com
#
# Option B — local Python climate service on :5001 (Vite proxies /api → :5001 when unset):
#   cd qgis-processing && python climate_server.py
#
# Option C — local Express proxy on :3001 (set CLIMATE_SERVICE_URL to Python in backend/.env):
# VITE_NODE_BACKEND_URL=http://localhost:3001
